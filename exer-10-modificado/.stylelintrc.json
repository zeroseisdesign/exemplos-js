{
  "extends": [
    "stylelint-config-recommended",
    "stylelint-config-prettier"
  ],
  "rules": {
    "color-no-hex": true,
    "color-hex-length": "short",
    "font-family-no-missing-generic-family-keyword": true,
    "function-no-unknown": true,
    "no-descending-specificity": true,
    "property-no-unknown": true,
    "selector-no-unknown": true,
    "unit-no-unknown": true,
    "at-rule-no-unknown": true,
    "comment-no-empty": true,
    "max-nesting-depth": 3,
    "max-line-length": 120,
    "no-empty-source": true,
    "no-extra-semicolons": true,
    "no-missing-end-of-source-newline": true,
    "block-closing-brace-newline-after": "always",
    "block-closing-brace-space-before": "never",
    "block-opening-brace-newline-after": "always",
    "block-opening-brace-space-after": "space",
    "declaration-colon-newline-after": "always",
    "declaration-colon-space-after": "always",
    "declaration-no-important": true,
    "function-comma-newline-after": "never",
    "function-comma-space-after": "always-single-line",
    "function-parentheses-newline-inside": "never",
    "function-parentheses-space-inside": "never-single-line",
    "function-whitespace-after": "always",
    "indentation": 2,
    "length-zero-no-unit": true,
    "max-nesting-depth": 3,
    "max-line-length": 120,
    "media-feature-parentheses-space-inside": "never",
    "media-feature-range-operator-space-after": "always",
    "media-feature-range-operator-space-before": "always",
    "media-query-list-comma-newline-after": "never",
    "media-query-list-comma-space-after": "always-single-line",
    "no-eol-whitespace": true,
    "no-missing-end-of-source-newline": true,
    "number-leading-zero": "always",
    "number-no-trailing-zeros": true,
    "property-case": "lower",
    "rule-empty-line-before": "always",
    "selector-class-pattern": "^[a-z][a-zA-Z0-9]*$",
    "selector-max-empty-lines": 0,
    "selector-max-specificity": "0,2,0",
    "selector-no-vendor-prefixes": true,
    "shorthand-property-no-redundant-values": true,
    "string-no-newline": true,
    "value-no-vendor-prefixes": true,
    "custom-property-pattern": "^[a-z][a-zA-Z0-9-]*$"
  }
}